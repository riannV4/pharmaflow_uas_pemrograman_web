{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "src/db/check_tables.ts",
    "src/db/check_users.ts",
    "src/db/migrate.ts",
    "src/db/reset_pass.ts"
  ]
}
